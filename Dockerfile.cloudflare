# This Dockerfile builds the Agent Awesome Cloudflare Container image.
#
# It compiles the gateway, harness, memory, workflow, and command services from
# their existing Go modules, then runs a single gateway process that supervises
# local dependencies inside the container.
FROM golang:1.26-bookworm AS build

WORKDIR /src

COPY gateway/go.mod gateway/go.sum ./gateway/
RUN cd gateway && go mod download

COPY harness/go.mod harness/go.sum ./harness/
RUN cd harness && go mod download

COPY memory/go.mod memory/go.sum ./memory/
RUN cd memory && go mod download

COPY workflow/go.mod workflow/go.sum ./workflow/
RUN cd workflow && go mod download

COPY command/go.mod command/go.sum ./command/
RUN cd command && go mod download

COPY gateway ./gateway
COPY harness ./harness
COPY memory ./memory
COPY workflow ./workflow
COPY command ./command

RUN cd gateway && CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -o /out/agent-gateway ./cmd/agent-gateway
RUN cd harness && CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -o /out/agent-awesome ./cmd/agent-awesome
RUN cd memory && CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -o /out/memoryd ./cmd/memoryd
RUN cd workflow && CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -o /out/workflowd ./cmd/workflowd
RUN cd command && CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -o /out/commandd ./cmd/commandd

FROM debian:bookworm-slim

RUN useradd --create-home --uid 10001 --shell /usr/sbin/nologin app \
  && mkdir -p /app/config /app/data /app/logs \
  && chown -R app:app /app

COPY --from=build /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
COPY --from=build /out/agent-gateway /usr/local/bin/agent-gateway
COPY --from=build /out/agent-awesome /usr/local/bin/agent-awesome
COPY --from=build /out/memoryd /usr/local/bin/memoryd
COPY --from=build /out/workflowd /usr/local/bin/workflowd
COPY --from=build /out/commandd /usr/local/bin/commandd
COPY deploy/cloudflare/config /app/config
COPY deploy/cloudflare/scripts/entrypoint.sh /usr/local/bin/agentawesome-cloudflare

RUN chmod 0755 /usr/local/bin/agentawesome-cloudflare

USER app
WORKDIR /app

ENV AGENTAWESOME_GATEWAY_ADDR=0.0.0.0:8070
ENV AGENTAWESOME_HARNESS_API_BASE_URL=http://127.0.0.1:8080/api
ENV AGENTAWESOME_CONTEXT_API_BASE_URL=http://127.0.0.1:8081/api/context
ENV AGENTAWESOME_MEMORY_MCP_URL=http://127.0.0.1:8090/mcp
ENV AGENTAWESOME_APP_NAME=agent_awesome
ENV AGENTAWESOME_USER_ID=doug
ENV AGENTAWESOME_GATEWAY_REQUEST_TIMEOUT=10m
ENV AGENTAWESOME_SERVICE_START_TIMEOUT=45s
ENV SLACK_ENABLED=false
ENV SLACK_SOCKET_MODE=false

EXPOSE 8070

ENTRYPOINT ["/usr/local/bin/agentawesome-cloudflare"]
