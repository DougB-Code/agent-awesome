  <div class="app-shell">
    <header class="topbar">
      <a class="brand" href="{{siteRootPath}}/agent-awesome/0.1/index.html" aria-label="Agent Awesome documentation home">
        <span class="brand-mark" aria-hidden="true">
          <img class="brand-logo" src="{{uiRootPath}}/img/agent-awesome-logo.png" alt="">
        </span>
        <span class="brand-copy">
          <span class="brand-name">Agent Awesome</span>
          <span class="brand-section">Documentation</span>
        </span>
      </a>
      <label id="search-field" class="search-control" aria-label="Search documentation">
        <span class="search-icon" aria-hidden="true"></span>
        <input id="search-input" type="search" placeholder="Search documentation...">
        <kbd>⌘K</kbd>
      </label>
      <div class="top-actions">
        <label class="select-control">
