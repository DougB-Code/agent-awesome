{
    "display_information": {
        "name": "Agent Awesome",
        "description": "A personal AI agent."
    },
    "features": {
        "app_home": {
            "home_tab_enabled": false,
            "messages_tab_enabled": true,
            "messages_tab_read_only_enabled": false
        },
        "bot_user": {
            "display_name": "Agent Awesome",
            "always_online": false
        },
        "slash_commands": [
            {
                "command": "/work",
                "description": "Check the Agent Awesome work queue immediately",
                "should_escape": false
            },
            {
                "command": "/approve",
                "description": "Give the agent approval to proceed",
                "should_escape": false
            },
            {
                "command": "/resume",
                "description": "Resume an in-flight task",
                "should_escape": false
            }
        ]
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "files:write",
                "app_mentions:read",
                "chat:write",
                "commands",
                "files:read",
                "im:history"
            ]
        },
        "pkce_enabled": false
    },
    "settings": {
        "event_subscriptions": {
            "bot_events": [
                "app_mention",
                "message.im"
            ]
        },
        "interactivity": {
            "is_enabled": true
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": true,
        "token_rotation_enabled": false,
        "is_mcp_enabled": false
    }
}