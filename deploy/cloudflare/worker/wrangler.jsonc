{
	"$schema": "node_modules/wrangler/config-schema.json",
	// This Worker routes public Slack Events traffic to one stateful pilot container.
	"name": "agent-awesome-pilot",
	"main": "src/index.ts",
	"compatibility_date": "2026-05-05",
	"workers_dev": false,
	"routes": [
		{
			"pattern": "agent-awesome.com/*",
			"zone_name": "agent-awesome.com"
		}
	],
	"observability": {
		"logs": {
			"enabled": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": false
		}
	},
	"vars": {
		"AGENTAWESOME_APP_NAME": "agent_awesome",
		"AGENTAWESOME_USER_ID": "beta",
		"AGENTAWESOME_CONTEXT_API_BASE_URL": "http://127.0.0.1:8081/api/context",
		"AGENTAWESOME_MEMORY_DOMAINS_JSON": "[{\"id\":\"memory\",\"label\":\"Memory\",\"endpoint\":\"http://127.0.0.1:8090/mcp\",\"health_url\":\"http://127.0.0.1:8090/healthz\"}]",
		"AGENTAWESOME_MEMORY_POLICY_JSON": "{\"actor\":\"agent:agent-awesome\",\"read_domains\":[\"memory\"],\"write_domains\":[\"memory\"],\"default_write_domain\":\"memory\",\"allowed_sensitivities\":[\"public\",\"internal\",\"private\"]}",
		"AGENTAWESOME_MEMORY_SERVICES_JSON": "[{\"domain_id\":\"memory\",\"name\":\"memory\",\"health_url\":\"http://127.0.0.1:8090/healthz\",\"command\":\"/usr/local/bin/memoryd\",\"arguments\":[\"--addr\",\"127.0.0.1:8090\",\"--db\",\"/app/data/memory/memory.db\",\"--data\",\"/app/data/memory/files\",\"--log-file\",\"/app/logs/memory.log\",\"--snapshot-url\",\"https://agent-awesome.com/internal/context-snapshot/memory\"],\"auto_start\":true}]",
		"AGENTAWESOME_MEMORY_SNAPSHOT_URL": "https://agent-awesome.com/internal/context-snapshot",
		"AGENTAWESOME_MEMORY_SNAPSHOT_PREFIX": "beta-pilot/memory",
		"AGENTAWESOME_MODEL_PROVIDER_ID": "openai",
		"AGENTAWESOME_MODEL_ID": "gpt-mini",
		"AGENTAWESOME_GATEWAY_REQUEST_TIMEOUT": "10m",
		"AGENTAWESOME_SERVICE_START_TIMEOUT": "45s",
		"SLACK_ENABLED": "true",
		"SLACK_SOCKET_MODE": "false",
		// Fill all three Slack allow-list ids before deploying a beta Worker.
		"SLACK_ALLOWED_TEAM_ID": "",
		"SLACK_ALLOWED_USER_ID": "",
		"SLACK_ALLOWED_CHANNEL_ID": ""
	},
	"secrets": {
		"required": [
			"AGENTAWESOME_GATEWAY_TOKEN",
			"AGENTAWESOME_PERSISTENCE_TOKEN",
			"SLACK_SIGNING_SECRET",
			"SLACK_BOT_TOKEN",
			"OPENAI_API_KEY"
		]
	},
	"r2_buckets": [
		{
			"binding": "CONTEXT_SNAPSHOTS",
			"bucket_name": "agent-awesome-beta-context"
		}
	],
	"containers": [
		{
			"class_name": "AgentAwesomeContainer",
			"image": "../../../Dockerfile.cloudflare",
			"image_build_context": "../../..",
			"max_instances": 1
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"name": "AGENT_AWESOME_CONTAINER",
				"class_name": "AgentAwesomeContainer"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": [
				"AgentAwesomeContainer"
			]
		}
	]
}
