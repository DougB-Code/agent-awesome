{
  "id": "cloudflare-context",
  "label": "Cloudflare Context",
  "harness": {
    "id": "cloudflare-context-harness",
    "label": "Cloudflare Context Harness",
    "api_base_url": "${AGENT_API_BASE_URL}",
    "context_api_base_url": "${AGENT_CONTEXT_API_BASE_URL}",
    "app_name": "${AGENT_APP_NAME}",
    "user_id": "${AGENT_USER_ID}",
    "working_directory": "${AGENTAWESOME_WORKSPACE_ROOT}/harness",
    "package_path": "./cmd/agent-awesome",
    "model_config": "${AGENTAWESOME_WORKSPACE_ROOT}/harness/model.yaml",
    "agent_config": "${AGENTAWESOME_WORKSPACE_ROOT}/harness/agent.yaml",
    "tool_config": "${AGENTAWESOME_WORKSPACE_ROOT}/harness/tool.cloudflare.yaml",
    "port": ${AGENT_API_PORT},
    "auto_start": ${AUTO_START_LOCAL_SERVICES}
  },
  "gateway": {
    "id": "cloudflare-context-gateway",
    "label": "Cloudflare Context Gateway",
    "api_base_url": "${AGENT_GATEWAY_BASE_URL}",
    "health_url": "${AGENT_GATEWAY_HEALTH_URL}",
    "working_directory": "${AGENTAWESOME_WORKSPACE_ROOT}/gateway",
    "package_path": "./cmd/agent-gateway",
    "harness_base_url": "${AGENT_API_BASE_URL}",
    "context_base_url": "${AGENT_CONTEXT_API_BASE_URL}",
    "memory_mcp_url": "https://agent-awesome.com/mcp",
    "app_name": "${AGENT_APP_NAME}",
    "user_id": "${AGENT_USER_ID}",
    "port": ${AGENT_GATEWAY_PORT},
    "auto_start": ${AUTO_START_LOCAL_SERVICES},
    "enabled": true
  },
  "memory_server_config": "${AGENTAWESOME_WORKSPACE_ROOT}/ui/runtime_profiles/memory/cloudflare_memory.json"
}
