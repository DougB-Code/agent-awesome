{
  "id": "local-dev",
  "label": "Local Dev Context",
  "harness": {
    "id": "local-dev-harness",
    "label": "Local Dev Harness",
    "api_base_url": "${AGENT_API_BASE_URL}",
    "context_api_base_url": "${AGENT_CONTEXT_API_BASE_URL}",
    "app_name": "${AGENT_APP_NAME}",
    "user_id": "${AGENT_USER_ID}",
    "working_directory": "${AGENTAWESOME_WORKSPACE_ROOT}/harness",
    "package_path": "./cmd/agent-awesome",
    "model_config": "${AGENTAWESOME_WORKSPACE_ROOT}/harness/model.yaml",
    "agent_config": "${AGENTAWESOME_WORKSPACE_ROOT}/harness/agent.yaml",
    "tool_config": "${AGENTAWESOME_WORKSPACE_ROOT}/harness/tool.local.yaml",
    "port": ${AGENT_API_PORT},
    "auto_start": ${AUTO_START_LOCAL_SERVICES}
  },
  "gateway": {
    "id": "local-dev-gateway",
    "label": "Local Dev Gateway",
    "api_base_url": "${AGENT_GATEWAY_BASE_URL}",
    "health_url": "${AGENT_GATEWAY_HEALTH_URL}",
    "status_url": "${AGENT_GATEWAY_STATUS_URL}",
    "working_directory": "${AGENTAWESOME_WORKSPACE_ROOT}/gateway",
    "package_path": "./cmd/agent-gateway",
    "harness_base_url": "${AGENT_API_BASE_URL}",
    "context_base_url": "${AGENT_CONTEXT_API_BASE_URL}",
    "memory_mcp_url": "${MEMORY_MCP_URL}",
    "app_name": "${AGENT_APP_NAME}",
    "user_id": "${AGENT_USER_ID}",
    "model_provider_id": "cloudflare",
    "model_id": "gemma-4",
    "port": ${AGENT_GATEWAY_PORT},
    "auto_start": ${AUTO_START_LOCAL_SERVICES},
    "enabled": true
  },
  "memory_domains": [
    {
      "id": "memory",
      "label": "Memory",
      "kind": "memory",
      "endpoint": "${MEMORY_MCP_URL}",
      "health_url": "${MEMORY_HEALTH_URL}",
      "working_directory": "${AGENTAWESOME_WORKSPACE_ROOT}/memory",
      "package_path": "./cmd/memoryd",
      "db_path": "${MEMORY_DB_PATH}",
      "data_dir": "${MEMORY_DATA_DIR}",
      "arguments": [
        "--addr",
        "${MEMORY_MCP_ADDR}",
        "--db",
        "${MEMORY_DB_PATH}",
        "--data",
        "${MEMORY_DATA_DIR}",
        "--firewall-policy",
        "${MEMORY_FIREWALL_POLICY_PATH}"
      ],
      "auto_start": ${AUTO_START_LOCAL_SERVICES},
      "enabled": true
    }
  ],
  "agent_memory": {
    "actor": "agent:local-dev",
    "read_domains": ["memory"],
    "write_domains": ["memory"],
    "default_write_domain": "memory",
    "allowed_sensitivities": ["public", "internal", "private"]
  }
}
