{
  "id": "cloudflare-family",
  "label": "Cloudflare Family",
  "harness": {
    "id": "cloudflare-family-harness",
    "label": "Cloudflare Harness",
    "api_base_url": "${AGENT_API_BASE_URL}",
    "context_api_base_url": "${AGENT_CONTEXT_API_BASE_URL}",
    "app_name": "${AGENT_APP_NAME}",
    "user_id": "family",
    "working_directory": "${AGENTAWESOME_WORKSPACE_ROOT}/harness",
    "package_path": "./cmd/agent-awesome",
    "model_config": "${AGENTAWESOME_WORKSPACE_ROOT}/harness/model.yaml",
    "agent_config": "${AGENTAWESOME_WORKSPACE_ROOT}/harness/agent.yaml",
    "tool_config": "${AGENTAWESOME_WORKSPACE_ROOT}/harness/tool.cloudflare.yaml",
    "port": ${AGENT_API_PORT},
    "auto_start": false
  },
  "gateway": {
    "id": "cloudflare-family-gateway",
    "label": "Cloudflare Gateway",
    "api_base_url": "${AGENT_GATEWAY_BASE_URL}",
    "health_url": "${AGENT_GATEWAY_HEALTH_URL}",
    "status_url": "${AGENT_GATEWAY_STATUS_URL}",
    "working_directory": "${AGENTAWESOME_WORKSPACE_ROOT}/gateway",
    "package_path": "./cmd/agent-gateway",
    "harness_base_url": "${AGENT_API_BASE_URL}",
    "context_base_url": "${AGENT_CONTEXT_API_BASE_URL}",
    "memory_mcp_url": "${AGENT_GATEWAY_MCP_URL}",
    "app_name": "${AGENT_APP_NAME}",
    "user_id": "family",
    "profile_id": "family",
    "auth_credential": "AGENTAWESOME_GATEWAY_TOKEN",
    "model_provider_id": "openai",
    "model_id": "gpt-5.4-mini",
    "port": ${AGENT_GATEWAY_PORT},
    "auto_start": false,
    "enabled": true
  },
  "workflow": {
    "id": "cloudflare-family-workflow",
    "label": "Cloudflare Workflow",
    "api_base_url": "${WORKFLOW_API_BASE_URL}",
    "health_url": "${WORKFLOW_HEALTH_URL}",
    "working_directory": "",
    "package_path": "",
    "definitions_dir": "",
    "db_path": "",
    "port": ${WORKFLOW_API_PORT},
    "auto_start": false,
    "enabled": false
  },
  "memory_domains": [
    {
      "id": "family",
      "label": "Family Memory",
      "kind": "memory",
      "endpoint": "${AGENT_GATEWAY_MCP_URL}/family",
      "health_url": "${AGENT_GATEWAY_HEALTH_URL}",
      "working_directory": "",
      "package_path": "",
      "db_path": "",
      "data_dir": "",
      "arguments": [],
      "auto_start": false,
      "enabled": true
    }
  ],
  "agent_memory": {
    "actor": "agent:family",
    "read_domains": ["family"],
    "write_domains": ["family"],
    "default_write_domain": "family",
    "allowed_sensitivities": ["public", "internal", "private"]
  }
}
