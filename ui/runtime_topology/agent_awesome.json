{
  "id": "agent-awesome",
  "label": "Agent Awesome",
  "harness": {
    "id": "agent-awesome",
    "label": "Agent Awesome Harness",
    "api_base_url": "${AGENT_API_BASE_URL}",
    "context_api_base_url": "${AGENT_CONTEXT_API_BASE_URL}",
    "app_name": "Agent Awesome",
    "user_id": "${AGENT_USER_ID}",
    "working_directory": "${AGENTAWESOME_WORKSPACE_ROOT}/harness",
    "executable_path": "${AGENTAWESOME_WORKSPACE_ROOT}/harness/build/bin/agent-awesome",
    "model_config": "${AGENTAWESOME_WORKSPACE_ROOT}/harness/model.yaml",
    "agent_config": "${AGENTAWESOME_WORKSPACE_ROOT}/harness/agent.yaml",
    "tool_config": "${AGENTAWESOME_WORKSPACE_ROOT}/harness/tool.local.yaml",
    "port": ${AGENT_API_PORT},
    "auto_start": ${AUTO_START_LOCAL_SERVICES}
  },
  "gateway": {
    "id": "agent-awesome-gateway",
    "label": "Agent Awesome Gateway",
    "api_base_url": "${AGENT_GATEWAY_BASE_URL}",
    "health_url": "${AGENT_GATEWAY_HEALTH_URL}",
    "status_url": "${AGENT_GATEWAY_STATUS_URL}",
    "working_directory": "${AGENTAWESOME_WORKSPACE_ROOT}/gateway",
    "executable_path": "${AGENTAWESOME_WORKSPACE_ROOT}/gateway/build/agent-gateway",
    "harness_base_url": "${AGENT_API_BASE_URL}",
    "context_base_url": "${AGENT_CONTEXT_API_BASE_URL}",
    "memory_mcp_url": "${MEMORY_MCP_URL}",
    "app_name": "Agent Awesome",
    "user_id": "${AGENT_USER_ID}",
    "model_provider_id": "openai",
    "model_id": "gpt-mini",
    "port": ${AGENT_GATEWAY_PORT},
    "auto_start": ${AUTO_START_LOCAL_SERVICES},
    "enabled": true
  },
  "runbook": {
    "id": "agent-awesome-runbook",
    "label": "Agent Awesome Runbook",
    "api_base_url": "${RUNBOOK_API_BASE_URL}",
    "health_url": "${RUNBOOK_HEALTH_URL}",
    "hosted_by_harness": false,
    "working_directory": "${AGENTAWESOME_WORKSPACE_ROOT}/harness",
    "executable_path": "${AGENTAWESOME_WORKSPACE_ROOT}/harness/build/bin/runbook-service",
    "definitions_dir": "${RUNBOOK_DEFINITIONS_DIR}",
    "db_path": "${RUNBOOK_DB_PATH}",
    "port": ${RUNBOOK_API_PORT},
    "auto_start": ${AUTO_START_LOCAL_SERVICES},
    "enabled": true
  },
  "memory_domains": [
    {
      "id": "memory",
      "label": "Memory",
      "kind": "memory",
      "endpoint": "${MEMORY_MCP_URL}",
      "health_url": "${MEMORY_HEALTH_URL}",
      "working_directory": "${AGENTAWESOME_WORKSPACE_ROOT}/memory",
      "executable_path": "${AGENTAWESOME_WORKSPACE_ROOT}/memory/build/bin/memoryd",
      "db_path": "",
      "data_dir": "${MEMORY_DATA_DIR}",
      "arguments": [
        "--addr",
        "${MEMORY_MCP_ADDR}",
        "--data",
        "${MEMORY_DATA_DIR}",
        "--domain-policy",
        "${MEMORY_DOMAIN_POLICY_PATH}"
      ],
      "auto_start": ${AUTO_START_LOCAL_SERVICES},
      "enabled": true
    }
  ],
  "mcp_servers": [
    {
      "id": "sourcecontrol",
      "label": "Source Control",
      "kind": "sourcecontrol",
      "endpoint": "${SOURCECONTROL_MCP_URL}",
      "health_url": "${SOURCECONTROL_HEALTH_URL}",
      "working_directory": "${AGENTAWESOME_WORKSPACE_ROOT}/../tools/agent-awesome.com/sourcecontrol",
      "executable_path": "${AGENTAWESOME_WORKSPACE_ROOT}/../tools/agent-awesome.com/sourcecontrol/build/bin/sourcecontrold",
      "db_path": "",
      "data_dir": "",
      "arguments": [
        "--addr",
        "${SOURCECONTROL_MCP_ADDR}",
        "--build-dir",
        "${AGENTAWESOME_WORKSPACE_ROOT}/build/sourcecontrol"
      ],
      "auto_start": ${AUTO_START_LOCAL_SERVICES},
      "enabled": true
    }
  ],
  "agent_memory": {
    "actor": "agent:agent-awesome",
    "read_domains": ["memory"],
    "write_domains": ["memory"],
    "default_write_domain": "memory",
    "allowed_sensitivities": ["public", "internal", "private"]
  }
}
