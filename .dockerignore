# This file keeps the Cloudflare container build context small and secret-free.
*

!Dockerfile.cloudflare
!.dockerignore

!gateway/
!gateway/**
!harness/
!harness/**
!memory/
!memory/**
!platform/
!platform/**
!workflow/
!workflow/**
!command/
!command/**
!build/
!build/remote-runtime/
!build/remote-runtime/**

!deploy/
!deploy/cloudflare/
!deploy/cloudflare/config/
!deploy/cloudflare/config/**
!deploy/cloudflare/scripts/
!deploy/cloudflare/scripts/**
!deploy/docker/
!deploy/docker/**

gateway/build/
harness/build/
memory/build/
platform/build/
workflow/build/
command/build/
